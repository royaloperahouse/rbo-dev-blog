                "image_caption": {
                  "type": "Text",
                  "config": {
                    "label": "Image Caption",
                    "placeholder": "Image Caption text"
                  }
                }
              },
              "repeat": {}
            },
            "video": {
              "type": "Slice",
              "fieldset": "Behind the scenes video",
              "description": "Behind the scenes digital event video",
              "icon": "videocam",
              "display": "list",
              "non-repeat": {
                "digital_event_video": {
                  "type": "Link",
                  "config": {
                    "select": "document",
                    "customtypes": ["digital_event_video"],
                    "label": "Digital event video",
                    "placeholder": "Digital event video"
                  }
                }
              },
              "repeat": {}
            }
          }
        }
      }
