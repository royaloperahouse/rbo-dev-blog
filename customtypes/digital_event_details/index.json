      "vs_price_details": {
        "type": "Text",
        "config": {
          "label": "Stream Price Details",
          "placeholder": "£6-£260"
        }
      },
      "vs_guidance": {
        "type": "Text",
        "config": {
          "label": "Guidance",
          "placeholder": "Guidance for event"
        }
      },
      "vs_guidance_details": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em",
          "label": "Guidance Details",
          "placeholder": "Further guidance details for event",
          "labels": ["block-quote", "quote-attribution"]
        }
      },
      "vs_hashtag": {
        "type": "Text",
        "config": {
          "label": "Hashtag",
          "placeholder": "Hashtag of event"
        }
      },
