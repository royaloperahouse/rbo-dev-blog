        "type": "StructuredText",
        "config": {
          "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em,hyperlink,list-item,o-list-item",
          "allowTargetBlank": true,
          "label": "Summary (Description)",
          "placeholder": "Description",
          "labels": [
            "block-quote",
            "quote-attribution",
            "collapsible-box-body",
            "collapsible-box-title"
          ]
        }
      },
      "synopsis_title": {
        "type": "Text",
        "config": {
          "label": "Story Section Title",
          "placeholder": "(Optional - defaults to \"Story\")"
        }
