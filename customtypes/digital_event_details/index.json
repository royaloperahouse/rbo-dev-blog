{
  "id": "digital_event_details",
  "json": {
    "Main": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta title",
          "placeholder": "Digital Event name"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta description",
          "placeholder": "Digital Event details"
        }
      },
      "vs_title": {
        "type": "StructuredText",
        "config": {
          "single": "heading4",
          "label": "Title",
          "placeholder": "Title",
          "useAsTitle": true
        }
      },
      "uid": {
        "type": "UID",
        "config": {
          "label": "Slug"
        }
      },
      "vs_videos": {
        "type": "Group",
        "config": {
          "fields": {
            "video": {
              "type": "Link",
              "config": {
                "select": "document",
                "customtypes": ["digital_event_video"],
                "label": "Video",
                "placeholder": "Digital event video to be linked"
              }
            }
          },
          "label": "Videos"
        }
      },
      "vs_event_details": {
        "type": "IntegrationFields",
        "config": {
          "catalog": "royal-opera-house--event_details_integration",
          "label": "Event details",
          "placeholder": "Event details to be linked"
        }
      },
      "diese_activity": {
        "type": "IntegrationFields",
        "config": {
          "catalog": "royal-opera-house--diese_activities",
          "label": "DIESE activity",
          "placeholder": "DIESE activity to be linked"
        }
      },
      "vs_is_cancelled": {
        "type": "Boolean",
        "config": {
          "default_value": false,
          "label": "Is cancelled (for live streams)"
        }
      },
      "vs_start_time": {
        "type": "Timestamp",
        "config": {
          "label": "Start Time",
          "placeholder": "Select a start date and time"
        }
      },
      "vs_end_time": {
        "type": "Timestamp",
        "config": {
          "label": "End Time",
          "placeholder": "Select an end date and time"
        }
      },
      "vs_availability_date": {
        "type": "Timestamp",
        "config": {
          "label": "Availability date",
          "placeholder": "Select availability date and time"
        }
      },
      "vs_availability_date_hide_timestamp": {
        "type": "Boolean",
        "config": {
          "placeholder_false": "Date and time",
          "placeholder_true": "Date only",
          "default_value": false,
          "label": "Availability date format"
        }
      },
      "vs_primary_cta_label": {
        "type": "Text",
        "config": {
          "label": "Primary CTA label on Digital Event Details page (Unsubscribed view)",
          "placeholder": "Subscribe to watch"
        }
      },
      "vs_primary_cta_url": {
        "type": "Text",
        "config": {
          "label": "Primary CTA url on Digital Event Details page (Unsubscribed view)",
          "placeholder": "/stream/offer"
        }
      },
