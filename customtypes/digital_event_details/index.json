        }
      },
      "vs_short_creatives_summary": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink",
          "allowTargetBlank": true,
          "label": "Short creatives summary",
          "placeholder": "Conducted by Jullia Jones",
