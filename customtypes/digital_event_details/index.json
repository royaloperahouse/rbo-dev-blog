        "type": "Group",
        "config": {
          "fields": {
            "name": {
              "type": "StructuredText",
              "config": {
                "single": "paragraph",
                "label": "Name",
                "placeholder": "Name of segment",
                "labels": ["block-quote", "quote-attribution"]
              }
            },
            "duration": {
              "type": "Number",
              "config": {
                "label": "Duration",
                "placeholder": "Duration in minutes"
              }
