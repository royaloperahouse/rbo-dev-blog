            "block-quote",
            "quote-attribution",
            "collapsible-box-body",
            "collapsible-box-title"
          ]
        }
      },
      "vs_synopsis": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em",
          "label": "Synopsis",
          "placeholder": "Synopsis"
        }
      },
