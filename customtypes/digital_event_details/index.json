    "Behind the scenes": {
      "vs_behind_the_scenes": {
        "type": "Slices",
        "fieldset": "Slice zone",
        "config": {
          "labels": null,
          "choices": {
            "image": {
              "type": "Slice",
              "fieldset": "Behind the scenes image",
              "description": "Behind the scenes image",
              "icon": "add_a_photo",
              "display": "list",
              "non-repeat": {
                "image": {
                  "type": "Image",
                  "config": {
                    "constraint": {
                      "width": 1200,
                      "height": 800
                    },
                    "thumbnails": [],
                    "label": "Image"
