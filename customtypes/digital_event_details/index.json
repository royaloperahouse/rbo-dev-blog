            {
              "name": "high_event_image",
              "width": 640,
              "height": 720
            },
            {
              "name": "tv_app_preview_image",
              "width": 975,
              "height": 1080
            },
            {
              "name": "tv_app_preview_image_selected",
              "width": 1200,
              "height": 600
            },
            {
              "name": "tv_app_rail_thumbnail",
              "width": 357,
              "height": 200
            }
