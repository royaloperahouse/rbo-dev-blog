{
  "id": "campaign",
  "json": {
    "Main": {
      "name": {
        "type": "Text",
        "config": {
          "label": "Name",
          "placeholder": "An identifier solely used within Prismic",
          "useAsTitle": true
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "ROYAL OPERA HOUSE RECOVERY CAMPAIGN"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em,hyperlink,image,embed,list-item,o-list-item",
          "allowTargetBlank": true,
          "label": "Campaign description (Rich text)",
          "placeholder": "Campaign description",
          "labels": [
            "block-quote",
            "quote-attribution",
            "collapsible-box-body",
            "collapsible-box-title"
          ]
        }
      }
    }
  },
  "label": "Campaign",
  "repeatable": true,
  "status": true,
  "format": "custom"
}
