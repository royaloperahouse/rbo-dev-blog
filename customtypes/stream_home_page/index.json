      },
      "help_cta_link": {
        "type": "Text",
        "config": {
          "label": "CTA link",
          "placeholder": "/stream/help"
        }
      }
    },
    "Proposition Page": {
      "proposition_page_elements": {
        "type": "Slices",
        "fieldset": "Slice zone",
        "config": {
          "labels": {},
          "choices": {
            "events_tray": {
              "type": "Slice",
              "fieldset": "Digital events and videos tray",
              "description": "Digital events and videos tray",
              "icon": "ondemand_video",
              "display": "list",
              "non-repeat": {
                "title": {
                  "type": "Text",
                  "config": {
                    "label": "Title",
