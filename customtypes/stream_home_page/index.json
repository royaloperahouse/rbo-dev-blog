                },
                "cta_text": {
                  "type": "Text",
                  "config": {
                    "label": "Block button",
                    "placeholder": "Subscribe"
                  }
                },
                "cta_link": {
                  "type": "Text",
                  "config": {
                    "label": "Subscribtion page link",
                    "placeholder": "/stream/offer"
                  }
                }
              },
              "repeat": {}
            },
            "event_promo": {
              "type": "Slice",
              "fieldset": "Digital Event Promo",
              "description": "Event Promo component",
              "icon": "featured_play_list",
              "display": "list",
              "non-repeat": {
                "digital_event": {
                  "type": "Link",
                  "config": {
                    "select": "document",
                    "customtypes": ["digital_event_details"],
                    "label": "Digital Event",
                    "placeholder": "Select Digital Event Details"
                  }
                },
                "timer_title": {
                  "type": "Text",
                  "config": {
                    "label": "Timer title",
