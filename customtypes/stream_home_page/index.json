{
  "id": "stream_home_page",
  "json": {
    "Main": {
      "header": {
        "type": "Link",
        "config": {
          "select": "document",
          "customtypes": ["compact_header"],
          "label": "Header",
          "placeholder": "Link to a valid Header component"
        }
      },
      "header_image": {
        "type": "Image",
        "config": {
          "constraint": {
            "width": 2048,
            "height": 1150
          },
          "thumbnails": [],
          "label": "Header Image"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "OPERA AND BALLET — ON DEMAND COMING SOON...",
          "useAsTitle": true
        }
      },
      "sub_title": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
          "label": "Subtitle",
          "placeholder": "Subtitle to be displayed on Stream Home Page"
        }
      },
      "banner_text": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
          "label": "Banner copy",
          "placeholder": "Banner copy to be displayed on Stream Home Page"
        }
      },
      "above_button_text": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
          "label": "Above button text",
          "placeholder": "Apply to be part of our test by filling out this form."
        }
      },
      "cta_text": {
        "type": "Text",
        "config": {
          "label": "CTA text",
          "placeholder": "Apply to join"
        }
      },
      "cta_link": {
        "type": "Text",
        "config": {
          "label": "CTA link",
          "placeholder": "/tickets-and-events/ballet-and-dance"
        }
      },
      "show_sponsor_logo": {
        "type": "Boolean",
        "config": {
          "placeholder_false": "Hide logo",
          "placeholder_true": "Show logo",
          "default_value": false,
          "label": "Show sponsor logo"
        }
      }
    },
    "Help": {
      "help_title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Stream help"
        }
      },
      "help_text": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
          "label": "Text",
          "placeholder": "You can read more about the streaming service, how to use and other troubleshooting advice on our Help page."
