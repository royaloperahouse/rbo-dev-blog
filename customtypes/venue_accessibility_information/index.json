{
  "id": "venue_accessibility_information",
  "json": {
    "Main": {
      "name": {
        "type": "Text",
        "config": {
          "label": "Name",
          "placeholder": "An identifier solely used within Prismic",
          "useAsTitle": true
        }
      },
      "venue_accessibility_title": {
        "type": "Text",
        "config": {
          "label": "Venue accessibility title",
          "placeholder": "Audio described"
        }
      },
      "venue_accessibility": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,heading3,heading4,heading5,heading6,strong,em,hyperlink,list-item,o-list-item",
          "allowTargetBlank": true,
          "label": "Venue accessibility description",
          "placeholder": "An audio described version of this performance is also available. Watch now on Youtube.",
          "labels": [
            "block-quote",
            "quote-attribution",
            "collapsible-box-body",
            "collapsible-box-title"
          ]
        }
      }
    }
  },
  "label": "Venue Accessibility Information",
  "repeatable": true,
  "status": true,
  "format": "custom"
}
