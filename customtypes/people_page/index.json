{
  "id": "people_page",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "slug"
        }
      },
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "Find out more about {person} at the Royal Ballet & Opera."
        }
      },
      "person_name": {
        "type": "Text",
        "config": {
          "label": "Person Name",
          "placeholder": "Kasper Holten"
        }
      },
      "role": {
        "type": "Text",
        "config": {
          "label": "Role",
          "placeholder": "Director"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "single": "strong,em",
          "label": "Description"
        }
      },
      "carousel_images": {
        "type": "Group",
        "config": {
          "fields": {
            "carousel_image": {
              "type": "Image",
              "config": {
                "constraint": {
                  "width": 1280,
                  "height": 960
                },
                "thumbnails": [
                  {
                    "name": "mobile_image",
                    "width": 460,
                    "height": 345
                  }
                ],
                "label": "Carousel Image"
              }
            }
          },
          "label": "Carousel Images"
        }
      },
      "biography": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink",
          "label": "Biography"
        }
      },
      "find_out_more": {
        "type": "StructuredText",
        "config": {
          "multi": "paragraph,strong,em,hyperlink",
          "label": "Watch"
        }
      },
      "selected_work": {
        "type": "Link",
        "config": {
          "select": "document",
          "customtypes": ["event_card"],
          "label": "selected work"
        }
      },
      "show_find_out_more": {
        "type": "Boolean",
        "config": {
          "default_value": false,
          "label": "Show find out more"
        }
      },
      "body": {
        "type": "Slices",
        "fieldset": "Slice zone",
        "config": {
          "labels": {},
          "choices": {
            "related_links": {
              "type": "Slice",
              "fieldset": "Related Links",
              "description": "Related Links",
              "icon": "insert_link",
              "display": "list",
              "non-repeat": {},
              "repeat": {
                "related_link": {
                  "type": "StructuredText",
                  "config": {
                    "single": "strong,em,hyperlink",
                    "allowTargetBlank": true,
                    "label": "Related Link"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "label": "People Page",
  "repeatable": true,
  "status": true,
  "format": "custom"
}
